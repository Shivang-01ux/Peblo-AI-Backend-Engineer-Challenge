# ── Peblo AI Mini — Environment Variables ──

# Application
APP_NAME=Peblo AI Mini
APP_VERSION=1.0.0
DEBUG=false

# Database (SQLite — zero setup required)
DATABASE_URL=sqlite:///./peblo.db

# Redis (optional — leave empty to use in-memory cache)
REDIS_URL=

# LLM Configuration (supports: groq, openai, gemini)
LLM_PROVIDER=groq
LLM_API_KEY=your-groq-api-key-here
LLM_MODEL=llama-3.3-70b-versatile

# Quiz Generation
SKIP_QUALITY_SCORING=true

# Embedding Model (for duplicate detection)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
